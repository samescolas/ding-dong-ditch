# Optional: password-protect the Ring management UI
# Leave empty for no password (local-only use)
#UI_PASSWORD=

# Storage backend: "local" (default) or "s3"
#STORAGE_BACKEND=local

# S3 configuration (only needed when STORAGE_BACKEND=s3)
# Works with AWS S3, MinIO, Backblaze B2, Cloudflare R2
#S3_BUCKET=my-recordings
#S3_REGION=us-east-1
#S3_ENDPOINT=https://s3.amazonaws.com
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_PREFIX=dingdongditch/

# MQTT integration (for Home Assistant)
# Publishes recording events and auto-discovers sensors in HA
#MQTT_ENABLED=true
#MQTT_BROKER=mqtt://emqx:1883
#MQTT_TOPIC_PREFIX=dingdongditch
#MQTT_DISCOVERY_PREFIX=homeassistant

# Optional: Cloudflare Tunnel for remote access
# Create a tunnel at https://one.dash.cloudflare.com -> Networks -> Tunnels
# Configure it to route your domain to http://app:3000
# Then paste the tunnel token here and start with: docker compose --profile tunnel up -d
#CLOUDFLARE_TUNNEL_TOKEN=
